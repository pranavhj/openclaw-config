#!/usr/bin/env python3
"""
openclaw-timeline — end-to-end trace of a message through the openclaw pipeline.

Shows: Discord recv → Gemini turn start → skill loaded → exec delegate →
       agent start → agent done (SENT) → Gemini stop (or continued responding)

Usage:
  openclaw-timeline [DATE]        # show today's timeline (or DATE: YYYY-MM-DD)
  openclaw-timeline --last N      # show last N delegate runs
  openclaw-timeline --follow      # tail the timeline log live
"""

import sys
import json
import os
import re
from datetime import datetime, timezone
from pathlib import Path

DATE = datetime.now(timezone.utc).strftime("%Y-%m-%d")
LOGDIR = Path("/tmp/openclaw")
SESSIONS_DIR = Path.home() / ".openclaw/agents/main/sessions"

# Parse args
args = sys.argv[1:]
last_n = None
follow = False
if "--follow" in args:
    follow = True
    args.remove("--follow")
if "--last" in args:
    idx = args.index("--last")
    last_n = int(args[idx + 1]) if idx + 1 < len(args) else 5
    args = args[:idx]
if args:
    DATE = args[0]


def parse_ts(ts_str):
    """Parse ISO timestamp → datetime."""
    if not ts_str:
        return None
    try:
        ts_str = ts_str.rstrip("Z")
        if "." in ts_str:
            return datetime.fromisoformat(ts_str + "+00:00")
        return datetime.fromisoformat(ts_str + "+00:00")
    except Exception:
        return None


def fmt_ts(dt, short=False):
    if dt is None:
        return "?"
    if short:
        return dt.strftime("%H:%M:%S.%f")[:-3]
    return dt.strftime("%Y-%m-%dT%H:%M:%S.%f")[:-3] + "Z"


def ms_diff(t1, t2):
    if t1 is None or t2 is None:
        return "?"
    delta = (t2 - t1).total_seconds() * 1000
    return f"+{delta:.0f}ms"


def load_timeline_events(date):
    """Load timeline JSONL events from delegate script."""
    path = LOGDIR / f"timeline-{date}.log"
    events = []
    if path.exists():
        for line in path.read_text().splitlines():
            line = line.strip()
            if not line:
                continue
            try:
                events.append(json.loads(line))
            except Exception:
                pass
    return events


def load_gateway_events(date):
    """Load relevant gateway log events — exec calls, Discord sends, model changes, errors."""
    path = LOGDIR / f"openclaw-{date}.log"
    events = []
    if not path.exists():
        return events
    for line in path.read_text().splitlines():
        line = line.strip()
        if not line:
            continue
        try:
            d = json.loads(line)
            meta = d.get("_meta", {})
            ts = meta.get("date", "")
            level = meta.get("logLevelName", "")
            msg0 = str(d.get("0", ""))
            msg1 = str(d.get("1", ""))
            msg2 = str(d.get("2", ""))

            ev = None

            # Discord send confirmation
            if "✅ Sent via Discord" in msg0:
                mid = re.search(r"Message ID: (\d+)", msg0)
                ev = {"ts": ts, "event": "discord_send", "msg_id": mid.group(1) if mid else "?"}

            # Exec command (delegate invocation by Gemini)
            elif "subsystem" in msg0 and "exec" in msg0 and "delegate" in msg1:
                ev = {"ts": ts, "event": "gemini_exec_delegate", "cmd_preview": msg1[:100]}

            # Skill dispatch — NEW MESSAGE received, skills being loaded (= Gemini turn start)
            elif "SKILL-DISPATCH-DEBUG" in msg0 and "loadSkillEntries" in msg0:
                names_match = re.search(r'names=\[([^\]]*)\]', msg0)
                body_match = re.search(r'body=([^\n"]{0,60})', msg0)
                body = body_match.group(1).strip() if body_match else ""
                ev = {"ts": ts, "event": "gemini_turn_start",
                      "count": len(names_match.group(1).split(",")) if names_match else "?",
                      "msg_preview": body}

            # Skill invocation result
            elif "SKILL-DISPATCH-DEBUG" in msg0 and "skillInvocation result" in msg0:
                invoked = "invocation=null" not in msg0
                ev = {"ts": ts, "event": "skill_invoked" if invoked else "skill_not_invoked",
                      "detail": msg0[msg0.find("skillInvocation"):msg0.find("skillInvocation") + 80]}

            # Model change / 429 error
            elif level == "ERROR" or ('"error"' in line and "429" in line):
                ev = {"ts": ts, "event": "model_error", "detail": (msg0 + " " + msg1)[:120]}

            # Web heartbeat — skip
            elif "web-heartbeat" in msg0 or "cron: timer armed" in msg2:
                continue

            if ev:
                events.append(ev)
        except Exception:
            pass
    return events


def group_gateway_turns(gw_events):
    """Group gateway events into per-message turns using gemini_turn_start as boundaries."""
    turns = []
    current = None
    for ev in gw_events:
        if ev.get("event") == "gemini_turn_start":
            if current:
                turns.append(current)
            current = {"start": ev, "events": [ev]}
        elif current:
            current["events"].append(ev)
    if current:
        turns.append(current)
    return turns


def load_gemini_sessions(date):
    """Extract key events from Gemini session JSONL files for the given date.

    Each session is a series of turns. For each user message, we track:
      - ts_user_msg: when Gemini received the message (turn start)
      - ts_tool_call: when Gemini fired exec (end of processing window)
      - ts_tool_result: when exec returned
      - ts_text_response: if Gemini produced text (expected: never after delegate)
    """
    sessions = []
    if not SESSIONS_DIR.exists():
        return sessions

    for jfile in sorted(SESSIONS_DIR.glob("*.jsonl")):
        if jfile.suffix == ".lock" or jfile.name == "sessions.json":
            continue
        try:
            lines = jfile.read_text().splitlines()
            if not lines:
                continue
            first_ts = None
            events = []
            current_model = "?"

            for line in lines:
                if not line.strip():
                    continue
                try:
                    d = json.loads(line)
                except Exception:
                    continue
                ts = d.get("timestamp", "")
                if not ts:
                    continue
                if first_ts is None:
                    first_ts = ts
                    if not ts.startswith(date):
                        break

                t = d.get("type", "")
                if t == "model_change":
                    current_model = d.get("modelId", "?")
                    events.append({"ts": ts, "event": "gemini_model", "model": current_model})
                elif t == "message":
                    msg = d.get("message", {})
                    role = msg.get("role", "")
                    content = msg.get("content", [])
                    text = ""
                    has_tool_use = False
                    tool_names = []
                    tool_cmd = ""
                    if isinstance(content, list):
                        for p in content:
                            if isinstance(p, dict):
                                if p.get("type") == "text":
                                    text = p.get("text", "")[:80]
                                elif p.get("type") in ("tool_use", "toolCall"):
                                    has_tool_use = True
                                    tool_names.append(p.get("name", "?"))
                                    # tool_use uses 'input', toolCall uses 'arguments'
                                    inp = p.get("input", p.get("arguments", {}))
                                    tool_cmd = inp.get("command", inp.get("cmd", ""))[:80]
                    if role == "user":
                        # Strip system/cron noise for preview
                        preview = text.strip()
                        if preview.startswith("System:") or "cron:" in preview:
                            preview = preview[:40] + " [system]"
                        events.append({"ts": ts, "event": "gemini_user_msg",
                                       "preview": preview[:60], "model": current_model})
                    elif role == "assistant":
                        if has_tool_use:
                            events.append({"ts": ts, "event": "gemini_tool_call",
                                           "tools": tool_names, "cmd": tool_cmd,
                                           "model": current_model})
                        elif text.strip():
                            events.append({"ts": ts, "event": "gemini_text_response",
                                           "preview": text[:60], "model": current_model})
                elif t == "custom" and d.get("customType") == "tool-result":
                    result_str = str(d.get("data", {}).get("result", ""))[:60]
                    events.append({"ts": ts, "event": "gemini_tool_result",
                                   "result": result_str})

            if events and first_ts and first_ts.startswith(date):
                sessions.append({"file": jfile.name, "first_ts": first_ts, "events": events})
        except Exception:
            pass
    return sessions


def build_gemini_turns(sessions):
    """From session events, build per-message turns with processing window metrics."""
    turns = []
    for sess in sessions:
        turn = None
        for ev in sess["events"]:
            etype = ev.get("event", "")
            if etype == "gemini_user_msg":
                if turn:
                    turns.append(turn)
                turn = {
                    "ts_recv": ev["ts"],
                    "msg_preview": ev.get("preview", ""),
                    "model": ev.get("model", "?"),
                    "ts_exec": None,
                    "ts_exec_result": None,
                    "ts_text": None,
                    "exec_cmd": "",
                    "text_after_exec": None,
                    "session": sess["file"],
                    "errors": [],
                }
            elif turn:
                if etype == "gemini_tool_call":
                    turn["ts_exec"] = ev["ts"]
                    turn["exec_cmd"] = ev.get("cmd", "")
                elif etype == "gemini_tool_result":
                    turn["ts_exec_result"] = ev["ts"]
                elif etype == "gemini_text_response":
                    if turn["ts_exec"]:  # text AFTER exec = bug
                        turn["text_after_exec"] = ev.get("preview", "")
                    turn["ts_text"] = ev["ts"]
                elif etype == "model_error":
                    turn["errors"].append(ev.get("detail", ""))
        if turn:
            turns.append(turn)
    return turns


def render_timeline(date):
    tl_events = load_timeline_events(date)
    gw_events = load_gateway_events(date)
    gem_sessions = load_gemini_sessions(date)
    gem_turns = build_gemini_turns(gem_sessions)

    # Group gateway events into per-turn blocks (from SKILL-DISPATCH-DEBUG if available)
    gw_turns = group_gateway_turns(gw_events)

    # Group delegate runs by recv event (from timeline JSONL)
    delegate_runs = []
    current_run = None
    for ev in tl_events:
        if ev.get("event") == "delegate_recv":
            if current_run:
                delegate_runs.append(current_run)
            current_run = {"recv": ev, "events": [ev]}
        elif current_run:
            current_run["events"].append(ev)
    if current_run:
        delegate_runs.append(current_run)

    if not gw_turns and not delegate_runs and not gem_sessions and not gem_turns:
        print(f"No timeline data for {date}")
        return

    print(f"{'═' * 72}")
    print(f"  openclaw timeline — {date}")
    print(f"  Phases: [G=Gemini processing] [D=Delegate overhead] [A=Agent/Claude]")
    print(f"{'═' * 72}")

    # ── Gemini processing window (from session JSONLs) ─────────────────────────
    delegate_turns = [t for t in gem_turns if t.get("ts_exec") and "delegate" in t.get("exec_cmd", "")]
    if gem_turns:
        print(f"\n{'─' * 72}")
        print(f"  GEMINI PROCESSING WINDOW  ({len(delegate_turns)} delegated, {len(gem_turns)} total turns)")
        print(f"  [G] = time Gemini spent thinking before firing exec")
        print(f"{'─' * 72}")
        for turn in gem_turns[-12:]:
            t_recv = parse_ts(turn["ts_recv"])
            t_exec = parse_ts(turn.get("ts_exec"))
            t_result = parse_ts(turn.get("ts_exec_result"))
            t_text = parse_ts(turn.get("ts_text"))
            model = turn.get("model", "?").replace("gemini-", "")
            msg = turn.get("msg_preview", "")[:50]
            cmd = turn.get("exec_cmd", "")[:50]
            errors = turn.get("errors", [])
            text_after = turn.get("text_after_exec")

            recv_str = fmt_ts(t_recv, short=True)

            if t_exec:
                think_ms = ms_diff(t_recv, t_exec)
                result_ms = ms_diff(t_exec, t_result) if t_result else "?"
                status = "✓ delegated"
            elif errors:
                think_ms = "ERR"
                result_ms = "—"
                status = f"✗ {errors[0][:40]}"
            else:
                think_ms = "—"
                result_ms = "—"
                status = "○ text only"

            print(f"  [{recv_str}]  [{model}]  [G={think_ms}]  {status}")
            if cmd:
                print(f"  {'':14}  cmd: {cmd}")
            if t_result:
                print(f"  {'':14}  exec returned in {result_ms}")
            if text_after is not None:
                print(f"  {'':14}  ⚠ GEMINI TEXT AFTER EXEC: \"{text_after[:50]}\"")
            if errors:
                for e in errors[:2]:
                    print(f"  {'':14}  ✗ {e[:60]}")

        # Summary stats
        think_times = []
        for t in delegate_turns:
            t_recv = parse_ts(t["ts_recv"])
            t_exec = parse_ts(t.get("ts_exec"))
            if t_recv and t_exec:
                ms = (t_exec - t_recv).total_seconds() * 1000
                think_times.append(ms)
        if think_times:
            avg = sum(think_times) / len(think_times)
            print(f"\n  Gemini processing window — avg: {avg:.0f}ms  "
                  f"min: {min(think_times):.0f}ms  max: {max(think_times):.0f}ms  "
                  f"(n={len(think_times)})")

    # ── Per-turn gateway view (from SKILL-DISPATCH-DEBUG if available) ─────────
    if gw_turns:
        print(f"\n{'─' * 72}")
        print(f"  GATEWAY TURNS  ({len(gw_turns)} turns — shows Gemini processing window)")
        print(f"{'─' * 72}")
        for turn in gw_turns[-10:]:  # last 10 turns
            start_ev = turn["start"]
            t_turn = parse_ts(start_ev.get("ts"))
            msg_prev = start_ev.get("msg_preview", "")[:55]
            skill_count = start_ev.get("count", "?")

            print(f"\n  [{fmt_ts(t_turn, short=True)}] ▶ MSG RECV  {msg_prev}...")
            print(f"  {'':14}  skills={skill_count}")

            t_exec = None
            t_discord = None
            skill_matched = None
            errors = []

            for ev in turn["events"]:
                t = parse_ts(ev.get("ts"))
                etype = ev.get("event", "")

                if etype == "gemini_turn_start":
                    continue
                elif etype == "skill_invoked":
                    skill_matched = True
                elif etype == "skill_not_invoked":
                    skill_matched = False
                elif etype == "gemini_exec_delegate":
                    t_exec = t
                    gemini_think = ms_diff(t_turn, t_exec)
                    print(f"  [{fmt_ts(t_exec, short=True)}] {gemini_think:>8}  [G] Gemini exec delegate")
                elif etype == "discord_send":
                    t_discord = t
                    total = ms_diff(t_turn, t_discord)
                    print(f"  [{fmt_ts(t_discord, short=True)}] {total:>8}  ✅ Discord sent (msg {ev.get('msg_id','?')})")
                elif etype == "model_error":
                    errors.append(ev.get("detail", "")[:60])

            if skill_matched is not None:
                matched_str = "✓ delegate skill matched" if skill_matched else "○ no skill — text response"
                print(f"  {'':14}  {matched_str}")

            if errors:
                for err in errors[:3]:
                    print(f"  {'':14}  ✗ ERR: {err}")

            # Summary line
            parts = []
            if t_exec:
                parts.append(f"Gemini think: {ms_diff(t_turn, t_exec)}")
            if t_discord:
                parts.append(f"Total: {ms_diff(t_turn, t_discord)}")
            if parts:
                print(f"  {'─' * 55}")
                print(f"  {' | '.join(parts)}")

    # ── Delegate script timing (from timeline JSONL, populated from next run) ──
    if delegate_runs:
        print(f"\n{'─' * 72}")
        print(f"  DELEGATE RUNS  ({len(delegate_runs)} — from delegate timeline log)")
        print(f"{'─' * 72}")
        for run in delegate_runs:
            recv = run["recv"]
            t0 = parse_ts(recv.get("ts"))
            ch = recv.get("channel", "?")
            msg = recv.get("msg_preview", "")[:50]

            print(f"\n  [{fmt_ts(t0, short=True)}] ▶ delegate_recv via {ch}: {msg}...")

            t_agent_start = None
            t_agent_done = None
            for ev in run["events"]:
                t = parse_ts(ev.get("ts"))
                etype = ev.get("event", "")
                lag = ms_diff(t0, t)

                if etype == "delegate_recv":
                    continue
                elif etype == "agent_start":
                    t_agent_start = t
                    print(f"  [{fmt_ts(t, short=True)}] {lag:>8}  [D] overhead → agent invoked (Claude)")
                elif etype == "agent_done":
                    t_agent_done = t
                    ec = ev.get("exit_code", "?")
                    out = ev.get("output", "")[:30]
                    dur = ev.get("duration_ms", "?")
                    status = "✓ SENT" if "SENT" in str(out) else f"✗ {out}"
                    print(f"  [{fmt_ts(t, short=True)}] {lag:>8}  [A] agent done [{status}] exit={ec} agent_ms={dur}")

            if t_agent_start and t_agent_done:
                parts = [
                    f"Delegate overhead: {ms_diff(t0, t_agent_start)}",
                    f"Agent time: {ms_diff(t_agent_start, t_agent_done)}",
                    f"Total: {ms_diff(t0, t_agent_done)}",
                ]
                print(f"  {'─' * 55}")
                print(f"  {' | '.join(parts)}")

    # ── Gemini sessions — model used, tool calls, post-delegate text ───────────
    if gem_sessions:
        print(f"\n{'─' * 72}")
        print(f"  GEMINI SESSIONS  ({len(gem_sessions)} today — tool calls & post-delegate behavior)")
        print(f"{'─' * 72}")
        for sess in gem_sessions[-5:]:
            print(f"\n  Session: {sess['file']}")
            t_last_exec = None
            for ev in sess["events"]:
                t = parse_ts(ev.get("ts"))
                etype = ev.get("event", "")
                ts_str = fmt_ts(t, short=True)

                if etype == "gemini_model":
                    print(f"  [{ts_str}]  MODEL  {ev.get('model', '?')}")
                elif etype == "gemini_user_msg":
                    print(f"  [{ts_str}]  ↓ USER  {ev.get('preview', '')[:60]}")
                elif etype == "gemini_tool_call":
                    tools = ", ".join(ev.get("tools", []))
                    prev = ev.get("preview", "")
                    t_last_exec = t
                    print(f"  [{ts_str}]  ⚙ EXEC  [{tools}] {prev[:50]}")
                elif etype == "gemini_text_response":
                    prev = ev.get("preview", "")
                    # Flag if Gemini responded with text AFTER an exec call
                    if t_last_exec is not None:
                        lag = ms_diff(t_last_exec, t)
                        print(f"  [{ts_str}]  ⚠ TEXT AFTER EXEC ({lag})  \"{prev[:50]}\"")
                    else:
                        print(f"  [{ts_str}]  ✍ TEXT (no prior exec)  \"{prev[:50]}\"")
                elif etype == "model_error":
                    print(f"  [{ts_str}]  ✗ ERR  {ev.get('detail', '')[:60]}")

    print(f"\n{'═' * 72}\n")


if follow:
    import time
    print(f"Following timeline log (Ctrl+C to stop)...")
    tl_path = LOGDIR / f"timeline-{DATE}.log"
    seen = set()
    while True:
        try:
            if tl_path.exists():
                for line in tl_path.read_text().splitlines():
                    if line and line not in seen:
                        seen.add(line)
                        try:
                            ev = json.loads(line)
                            t = parse_ts(ev.get("ts"))
                            print(f"[{fmt_ts(t, short=True)}] {ev.get('event','?'):25} {json.dumps({k:v for k,v in ev.items() if k not in ('ts','event')})}")
                        except Exception:
                            pass
            time.sleep(1)
        except KeyboardInterrupt:
            break
else:
    render_timeline(DATE)

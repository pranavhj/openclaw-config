#!/bin/bash
# Single delegation command — Gemini calls this, script handles the rest
# Flow: Gemini exec → this script → Claude agent → Discord response
CHANNEL="$1"
TARGET="$2"
shift 2
MESSAGE="$*"

LOGDIR="/tmp/openclaw"
LOGFILE="$LOGDIR/delegate-$(date +%Y-%m-%d).log"
TIMELINE_LOG="$LOGDIR/timeline-$(date +%Y-%m-%d).log"
LOCKFILE="$LOGDIR/delegate.lock"
mkdir -p "$LOGDIR"

# Millisecond timestamp helper (UTC ISO-8601)
ts_ms() { date '+%Y-%m-%dT%H:%M:%S.%3NZ' --utc; }
TS_RECV=$(ts_ms)

# JSON-safe string helper (escapes quotes and backslashes for timeline log)
json_safe() { printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g' | tr '\n' ' '; }

# --- Log: delegate_recv ---
printf '{"ts":"%s","event":"delegate_recv","channel":"%s","target":"%s","msg_len":%d,"msg_preview":"%s"}\n' \
  "$TS_RECV" "$CHANNEL" "$TARGET" "${#MESSAGE}" "$(json_safe "${MESSAGE:0:80}")" >> "$TIMELINE_LOG"

# --- Sanitization ---
ORIG_LEN=${#MESSAGE}
RSQUOTE=$'\xe2\x80\x99'  # U+2019 RIGHT SINGLE QUOTATION MARK
LDQUOTE=$'\xe2\x80\x98'  # U+2018 LEFT SINGLE QUOTATION MARK (replaces backtick)
MESSAGE="${MESSAGE//$'\''/$RSQUOTE}"
MESSAGE="${MESSAGE//\`/$LDQUOTE}"
MESSAGE="${MESSAGE//$'\n'/ }"  # OC-016 fix: newlines break bash exec
SANITIZED_LEN=${#MESSAGE}
CHARS_REPLACED=$(( ORIG_LEN - SANITIZED_LEN ))

TS_SANITIZE=$(ts_ms)
printf '{"ts":"%s","event":"sanitize","orig_len":%d,"sanitized_len":%d,"chars_replaced":%d}\n' \
  "$TS_SANITIZE" "$ORIG_LEN" "$SANITIZED_LEN" "$CHARS_REPLACED" >> "$TIMELINE_LOG"

# --- Lock: prevent duplicate concurrent runs ---
if ! mkdir "$LOCKFILE" 2>/dev/null; then
  TS_BLOCKED=$(ts_ms)
  printf '{"ts":"%s","event":"lock_blocked","msg":"duplicate run detected"}\n' "$TS_BLOCKED" >> "$TIMELINE_LOG"
  echo "lock_blocked: duplicate run at $TS_BLOCKED" >> "$LOGFILE"
  echo "SENT"
  exit 0
fi
trap "rmdir '$LOCKFILE' 2>/dev/null" EXIT

TS_LOCK=$(ts_ms)
printf '{"ts":"%s","event":"lock_acquired"}\n' "$TS_LOCK" >> "$TIMELINE_LOG"

# --- Discover projects ---
PROJECTS=$(ls /home/pranav/projects/ 2>/dev/null | tr '\n' ', ')

# --- Match project from message (for cwd) ---
WORK_DIR="/home/pranav/projects/openclaw"
for proj in $(ls /home/pranav/projects/ 2>/dev/null); do
  if echo "$MESSAGE" | grep -qi "$proj"; then
    WORK_DIR="/home/pranav/projects/$proj"
    break
  fi
done

# --- Log: human-readable header ---
{
  echo "=== $(date '+%Y-%m-%d %H:%M:%S %Z') ==="
  echo "channel: $CHANNEL"
  echo "target: $TARGET"
  echo "message: ${MESSAGE:0:200}"
  echo "msg_len: $ORIG_LEN (sanitized: $SANITIZED_LEN)"
  echo "projects: ${PROJECTS:-none}"
} >> "$LOGFILE"

# --- Build prompt ---
PROMPT_FILE=$(mktemp /tmp/delegate-prompt-XXXXXX.txt)
cat > "$PROMPT_FILE" << 'HEADER'
## Reply
HEADER
printf 'Channel: %s\nTarget: %s\n\n' "$CHANNEL" "$TARGET" >> "$PROMPT_FILE"
printf '## Known projects in /home/pranav/projects/\n%s\n\n' "${PROJECTS:-none}" >> "$PROMPT_FILE"
printf '## Request\n%s\n' "$MESSAGE" >> "$PROMPT_FILE"

PROMPT_SIZE=$(wc -c < "$PROMPT_FILE")
TS_PROMPT=$(ts_ms)
printf '{"ts":"%s","event":"prompt_ready","file":"%s","bytes":%d}\n' \
  "$TS_PROMPT" "$PROMPT_FILE" "$PROMPT_SIZE" >> "$TIMELINE_LOG"

# --- Run agent ---
TS_AGENT_START=$(ts_ms)
printf '{"ts":"%s","event":"agent_start","channel":"%s","target":"%s"}\n' \
  "$TS_AGENT_START" "$CHANNEL" "$TARGET" >> "$TIMELINE_LOG"

OUTPUT=$(cd /home/pranav/projects/openclaw && agent --continue --permission-mode bypassPermissions --print "$(cat "$PROMPT_FILE")" 2>&1)
EXIT_CODE=$?
rm -f "$PROMPT_FILE"

TS_AGENT_DONE=$(ts_ms)
DURATION_MS=$(( $(date -d "$TS_AGENT_DONE" +%s%3N 2>/dev/null || echo 0) - $(date -d "$TS_AGENT_START" +%s%3N 2>/dev/null || echo 0) ))

# --- Log: agent_done ---
printf '{"ts":"%s","event":"agent_done","exit_code":%d,"duration_ms":%d,"output_preview":"%s"}\n' \
  "$TS_AGENT_DONE" "$EXIT_CODE" "$DURATION_MS" "$(json_safe "${OUTPUT:0:60}")" >> "$TIMELINE_LOG"

# --- Failure handling ---
if [ "$EXIT_CODE" -ne 0 ] && [[ "$OUTPUT" != *"SENT"* ]]; then
  TS_FAIL=$(ts_ms)
  printf '{"ts":"%s","event":"failure_detected","exit_code":%d,"output_preview":"%s"}\n' \
    "$TS_FAIL" "$EXIT_CODE" "$(json_safe "${OUTPUT:0:100}")" >> "$TIMELINE_LOG"

  # Notify user on Discord so they're not left waiting
  openclaw message send --channel "$CHANNEL" --target "$TARGET" \
    --message "Delegation failed (exit $EXIT_CODE). Please try again.
-# sent by delegate" 2>/dev/null
  NOTIFY_EXIT=$?

  TS_NOTIFY=$(ts_ms)
  printf '{"ts":"%s","event":"failure_notified","notify_exit":%d}\n' \
    "$TS_NOTIFY" "$NOTIFY_EXIT" >> "$TIMELINE_LOG"

  echo "failure_notified: exit=$NOTIFY_EXIT at $TS_NOTIFY" >> "$LOGFILE"
  OUTPUT="SENT"  # Tell Gemini to stop
fi

# --- Log: delegate_exit ---
TS_EXIT=$(ts_ms)
TOTAL_MS=$(( $(date -d "$TS_EXIT" +%s%3N 2>/dev/null || echo 0) - $(date -d "$TS_RECV" +%s%3N 2>/dev/null || echo 0) ))

printf '{"ts":"%s","event":"delegate_exit","total_ms":%d,"final_output":"%s"}\n' \
  "$TS_EXIT" "$TOTAL_MS" "$(json_safe "${OUTPUT:0:40}")" >> "$TIMELINE_LOG"

# Human-readable summary
{
  echo "ts_recv: $TS_RECV"
  echo "ts_agent_start: $TS_AGENT_START"
  echo "ts_agent_done: $TS_AGENT_DONE"
  echo "ts_exit: $TS_EXIT"
  echo "duration_agent_ms: $DURATION_MS"
  echo "duration_total_ms: $TOTAL_MS"
  echo "exit_code: $EXIT_CODE"
  echo "output: ${OUTPUT:0:200}"
  echo "status: done"
  echo ""
} >> "$LOGFILE"

# Pass through output so openclaw sees SENT
echo "$OUTPUT"
